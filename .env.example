# Copy to .env and fill in. NEVER commit a real .env (it is gitignored).
# The app reads every value from the environment; nothing here is baked into images.

# --- Claude Code CLI auth (required when running in --bare / container mode) ---
# Bare mode (recommended in containers/CI) authenticates with this key.
# For local interactive use you can instead rely on `claude` being logged in.
ANTHROPIC_API_KEY=

# --- Skill Smith runtime config (all optional; override skill-smith.config.json) ---
# Engine model for `claude -p`. "" uses the CLI default.
SKILL_SMITH_MODEL=claude-opus-4-8
# Pass --bare to the CLI (skips local context; needs ANTHROPIC_API_KEY).
SKILL_SMITH_BARE=false
# Path/name of the claude binary (tests override this with a mock).
SKILL_SMITH_CLAUDE_BIN=claude
# Per-job artifact root.
SKILL_SMITH_WORKSPACE_DIR=./workspace
# Cost guardrails.
SKILL_SMITH_MAX_PARALLELISM=3
SKILL_SMITH_INVOCATION_CEILING=40
# Retry/backoff.
SKILL_SMITH_RETRY_MAX=3
SKILL_SMITH_RETRY_BASE_DELAY_MS=1000

# --- Ports ---
# Backend API/SSE port (frontend dev proxy + nginx target use this).
SKILL_SMITH_PORT=4000

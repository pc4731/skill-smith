{
  "$meta": { "name": "Skill Smith", "direction": "dark-professional", "defaultMode": "dark" },
  "color": {
    "dark": {
      "bg": "#0e1116",
      "surface": "#161b22",
      "surfaceRaised": "#1c232c",
      "console": "#0a0d12",
      "border": "#2a313c",
      "borderStrong": "#3a434f",
      "text": "#e6edf3",
      "textMuted": "#9aa7b4",
      "textFaint": "#6b7682",
      "accent": "#f0a02a",
      "accentHover": "#ffb645",
      "accentText": "#1a1205",
      "accentTint": "#2a2110",
      "info": "#4ea1ff",
      "success": "#3fb950",
      "warning": "#d29922",
      "danger": "#f85149",
      "focus": "#7cc4ff"
    },
    "light": {
      "bg": "#f6f8fa",
      "surface": "#ffffff",
      "surfaceRaised": "#ffffff",
      "console": "#0a0d12",
      "border": "#d7dde4",
      "borderStrong": "#b7c0ca",
      "text": "#1b222b",
      "textMuted": "#5a6573",
      "textFaint": "#8a95a1",
      "accent": "#b3650a",
      "accentHover": "#985407",
      "accentText": "#ffffff",
      "accentTint": "#fbf1de",
      "info": "#1f6feb",
      "success": "#1a7f37",
      "warning": "#9a6700",
      "danger": "#cf222e",
      "focus": "#1f6feb"
    }
  },
  "typography": {
    "fontSans": "Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, sans-serif",
    "fontMono": "ui-monospace, SFMono-Regular, Menlo, Consolas, 'JetBrains Mono', monospace",
    "scale": { "xs": "12px", "sm": "13px", "base": "15px", "lg": "18px", "xl": "22px", "2xl": "28px", "3xl": "36px" },
    "weight": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "lineHeight": { "tight": 1.25, "normal": 1.5, "relaxed": 1.7 }
  },
  "space": { "0": "0", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "24px", "6": "32px", "7": "48px", "8": "64px" },
  "radius": { "sm": "6px", "md": "10px", "lg": "14px", "pill": "999px" },
  "shadow": {
    "sm": "0 1px 2px rgba(0,0,0,0.4)",
    "md": "0 4px 16px rgba(0,0,0,0.5)",
    "focusRing": "0 0 0 3px var(--color-focus)"
  },
  "motion": { "fast": "120ms ease", "base": "200ms ease", "slow": "320ms ease" },
  "component": {
    "promptBar": { "minHeight": "56px", "radius": "md", "bg": "surface", "border": "border", "focusBorder": "accent" },
    "chip": { "radius": "pill", "padX": "3", "padY": "2", "selectedBorder": "accent", "selectedBg": "accentTint" },
    "stepper": { "railColor": "border", "runningColor": "accent", "doneColor": "success", "failedColor": "danger", "pendingColor": "textFaint" },
    "console": { "bg": "console", "text": "text", "font": "fontMono", "fontSize": "sm", "radius": "md" },
    "costMeter": { "bg": "surfaceRaised", "font": "fontMono", "warnColor": "warning", "overColor": "danger" }
  }
}
